{
  "name": "@time2leave/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "icons": "node ./scripts/generate-icons.mjs",
    "env:pull": "bash ./scripts/pull-env.sh",
    "env:set": "bash ./scripts/set-env-var.sh",
    "eas": "bash -c 'set -a && . ./.env && set +a && eas \"$@\"' --"
  },
  "dependencies": {
    "@expo/ui": "~55.0.13",
    "@react-native-google-signin/google-signin": "^14.0.0",
    "@react-native/assets-registry": "0.83.6",
    "@react-native/js-polyfills": "0.83.6",
    "@react-native/normalize-colors": "0.83.6",
    "@react-native/virtualized-lists": "0.83.6",
    "@tanstack/react-query": "^5.62.0",
    "@time2leave/shared": "*",
    "expo": "^55.0.0",
    "expo-apple-authentication": "~55.0.13",
    "expo-constants": "~55.0.0",
    "expo-dev-client": "~55.0.30",
    "expo-glass-effect": "~55.0.0",
    "expo-linear-gradient": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-secure-store": "~55.0.0",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "expo-symbols": "~55.0.0",
    "expo-system-ui": "~55.0.0",
    "expo-updates": "~55.0.21",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.31.0",
    "react-native-google-places-autocomplete": "^2.5.7",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~4.2.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-worklets": "^0.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.0",
    "typescript": "~5.9.0"
