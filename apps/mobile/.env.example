# Copy to apps/mobile/.env for local dev. Expo only exposes vars
# prefixed with `EXPO_PUBLIC_` to the client bundle.

# Backend base URL the mobile client talks to. Use your laptop's
# LAN IP (NOT localhost) so a phone running Expo Go can reach it.
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# OAuth client IDs from Google Cloud Console. The web one is read by
# Expo Go on iOS for the in-app sign-in flow; production iOS / Android
# builds use their own native client IDs configured in app.json.
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=

# Browser-restricted Google Maps key for Places autocomplete on the
# new-trip screen. iOS / Android builds should use platform-restricted
# keys instead — leave this unset there if you've baked them into the
# native config.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Local-dev escape hatch matching backend ENABLE_DEV_LOGIN. When set,
# the splash screen also offers a "Continue as dev user" button that
# hits POST /api/v1/auth/dev-login.
EXPO_PUBLIC_ENABLE_DEV_LOGIN=true
EXPO_PUBLIC_DEV_LOGIN_EMAIL=dev@example.com
