# Copy to backend/.env for local dev. Every value shown here is also the
# default baked into app/config.py, so this file is informational.

APP_ENV=local

# ---- MySQL --------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Abcd1234
MYSQL_DATABASE=time2leave

# Host-side ports for docker-compose.dev.yml. Override these if something on
# your machine (e.g. a local MySQL install) already owns 3306/8000/5173.
# The defaults intentionally map MySQL to 3307 on the host to avoid clashing
# with a Homebrew/system MySQL on 3306.
MYSQL_HOST_PORT=3307
API_HOST_PORT=8000
FRONTEND_HOST_PORT=5173

# ---- Data provider -------------------------------------------------------
# "fixture" = deterministic fake data, no external calls. "google" = call
# the Routes Matrix API (requires GOOGLE_MAPS_API_KEY).
DATA_PROVIDER=fixture
# GOOGLE_MAPS_API_KEY=

# ---- Google sign-in ------------------------------------------------------
# OAuth Client IDs for "Sign in with Google", comma-separated.
#
# In prod this typically holds three IDs from the same GCP project:
#   - Web (used by apps/web via Google Identity Services in the browser)
#   - iOS (used by apps/mobile on iOS via @react-native-google-signin)
#   - Android (used by apps/mobile on Android, ditto)
#
# A token is accepted if its `aud` claim matches *any* of the listed IDs,
# so all three clients can hit the same `/api/v1/auth/google` endpoint.
# Local dev can skip this and use /auth/dev-login (gated by
# ENABLE_DEV_LOGIN below).
# GOOGLE_OAUTH_CLIENT_ID=web-id.apps.googleusercontent.com,ios-id.apps.googleusercontent.com,android-id.apps.googleusercontent.com

# ---- Sessions ------------------------------------------------------------
# HMAC secret used to sign session JWTs. ALWAYS override in prod (loaded
# from AWS Secrets Manager). The default below is intentionally weak so
# you remember to change it.
SESSION_SECRET=dev-only-change-me
SESSION_COOKIE_NAME=tlh_session
SESSION_TTL_HOURS=168
# Set when API and frontend live on different subdomains so the cookie is
# shared, e.g. .time2leave.com.
# SESSION_COOKIE_DOMAIN=

# ---- Access control ------------------------------------------------------
# Comma-separated. Listed users get is_admin: true and access to the
# /admin/* endpoints (allowlist management, manual data-gathering).
ADMIN_EMAILS=dev@example.com

# Comma-separated. Inserted into auth_allowlist on every startup
# (idempotent). Use this to pre-load invitees from infrastructure.
AUTH_ALLOWLIST_BOOTSTRAP=dev@example.com

# Allow POST /auth/dev-login outside of prod. Local dev convenience so you
# don't need a real Google OAuth client to test authenticated flows.
# Forced off in prod regardless of this value.
ENABLE_DEV_LOGIN=true

# ---- Quotas / cost ceilings ---------------------------------------------
# Caps below are *production* values (1 trip / 1 mutation per week)
# because every trip create / address change triggers a real Routes
# Matrix backfill (~840 elements ≈ $8.40 worth of API calls). They are
# left commented out here on purpose: when APP_ENV=local AND the env
# var is unset, `app/config.py:_apply_local_dev_quotas` automatically
# bumps each one to a dev-friendly value (100 / 100 / 1000 / 100), so
# you can churn through hundreds of fake trips without touching real
# spend. Uncomment any line to opt back into the production cap for
# focused testing of the cap-enforcement paths.
# MAX_TRIPS_PER_USER=1
# Admins (emails in ADMIN_EMAILS) get the elevated cap; lets the operator
# keep a personal trip alongside a smoke-test trip without raising the
# limit for everyone else.
# MAX_TRIPS_PER_ADMIN=2
# MAX_TRIPS_TOTAL=10
# Rolling-7-day cap on trip creates + address-changing patches per user.
# MAX_TRIP_MUTATIONS_PER_WEEK=1
# Weekly cron (Mon 01:00 PT) refuses to start if the planned Routes
# Matrix call count would exceed this. Tune up only after you
# understand the billing impact.
MAX_WEEKLY_ROUTES_CALLS=150000

# ---- CORS ----------------------------------------------------------------
# Comma-separated origins allowed by CORS outside of prod. In prod the
# allowlist is hard-wired to https://time2leave.com and
# https://www.time2leave.com.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Admin endpoints -----------------------------------------------------
# Mount the admin router. Always-on; access is then gated by ADMIN_EMAILS.
ENABLE_ADMIN_API=true
