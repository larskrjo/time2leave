# Copy to backend/.env for local dev. Every value shown here is also the
# default baked into app/config.py, so this file is informational.

APP_ENV=local

# ---- MySQL --------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Abcd1234
MYSQL_DATABASE=time2leave

# Host-side ports for docker-compose.dev.yml. Override these if something on
# your machine (e.g. a local MySQL install) already owns 3306/8000/5173.
# The defaults intentionally map MySQL to 3307 on the host to avoid clashing
# with a Homebrew/system MySQL on 3306.
MYSQL_HOST_PORT=3307
API_HOST_PORT=8000
FRONTEND_HOST_PORT=5173

# ---- Data provider -------------------------------------------------------
# "fixture" = deterministic fake data, no external calls. "google" = call
# the Routes Matrix API (requires GOOGLE_MAPS_API_KEY).
DATA_PROVIDER=fixture
# GOOGLE_MAPS_API_KEY=

# ---- Google sign-in ------------------------------------------------------
# OAuth Client ID for "Sign in with Google" via Google Identity Services.
# Required for the real /auth/google flow. Local dev can skip this and use
# /auth/dev-login (gated by ENABLE_DEV_LOGIN below).
# GOOGLE_OAUTH_CLIENT_ID=

# ---- Sessions ------------------------------------------------------------
# HMAC secret used to sign session JWTs. ALWAYS override in prod (loaded
# from AWS Secrets Manager). The default below is intentionally weak so
# you remember to change it.
SESSION_SECRET=dev-only-change-me
SESSION_COOKIE_NAME=tlh_session
SESSION_TTL_HOURS=168
# Set when API and frontend live on different subdomains so the cookie is
# shared, e.g. .larsjohansen.com.
# SESSION_COOKIE_DOMAIN=

# ---- Access control ------------------------------------------------------
# Comma-separated. Listed users get is_admin: true and access to the
# /admin/* endpoints (allowlist management, manual data-gathering).
ADMIN_EMAILS=dev@example.com

# Comma-separated. Inserted into auth_allowlist on every startup
# (idempotent). Use this to pre-load invitees from infrastructure.
AUTH_ALLOWLIST_BOOTSTRAP=dev@example.com

# Allow POST /auth/dev-login outside of prod. Local dev convenience so you
# don't need a real Google OAuth client to test authenticated flows.
# Forced off in prod regardless of this value.
ENABLE_DEV_LOGIN=true

# ---- Quotas / cost ceilings ---------------------------------------------
MAX_TRIPS_PER_USER=1
MAX_TRIPS_TOTAL=10
# Rolling-7-day cap on trip creates + address-changing patches per user.
# Each is a fresh Routes Matrix backfill (~840 elements ≈ $8.40), so
# this cap is the main lever bounding worst-case Google Maps spend.
MAX_TRIP_MUTATIONS_PER_WEEK=1
# Friday cron refuses to start if the planned Routes Matrix call count
# would exceed this. Tune up only after you understand the billing impact.
MAX_WEEKLY_ROUTES_CALLS=150000

# ---- CORS ----------------------------------------------------------------
# Comma-separated origins allowed by CORS outside of prod. In prod the
# allowlist is hard-wired to https://traffic.larsjohansen.com.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://traffic.larsjohansen.com:5173

# ---- Admin endpoints -----------------------------------------------------
# Mount the admin router. Always-on; access is then gated by ADMIN_EMAILS.
ENABLE_ADMIN_API=true
