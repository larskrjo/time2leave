# Frontend environment variables. Copy to `.env.local` to customize.

# Base URL for the backend API. Leave unset to use:
#   http://localhost:8000    when running `npm run dev`
#   https://api.traffic.larsjohansen.com    in production builds
# VITE_API_BASE_URL=

# Google Maps browser key for the Places autocomplete on the new-trip
# form. Referer-restricted to prod domains in deployed builds.
# VITE_GOOGLE_MAPS_API_KEY=

# Opt in to loading Places on localhost. Off by default because most
# browser keys reject `http://localhost:*` with RefererNotAllowedMapError,
# which paints red error icons into the input. Set this to `true` only
# if you've added localhost to your key's allowed referers.
# VITE_ENABLE_PLACES_ON_LOCALHOST=true
